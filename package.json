{
  "name": "ha-codex-bridge",
  "version": "0.8.1",
  "private": true,
  "type": "module",
  "description": "Build and security checks for the Home Assistant Codex Bridge panel.",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "build": "npm run build:panel && npm run build:pdf-worker",
    "build:panel": "esbuild frontend/src/codex-bridge-panel.js --bundle --format=esm --platform=browser --target=es2022 --charset=utf8 --legal-comments=eof --outfile=custom_components/codex_bridge/frontend/codex-bridge-panel.js",
    "build:pdf-worker": "esbuild node_modules/pdfjs-dist/build/pdf.worker.min.mjs --bundle --format=esm --platform=browser --target=es2022 --charset=utf8 --legal-comments=eof --outfile=custom_components/codex_bridge/frontend/codex-bridge-pdf-worker.js",
    "lint": "eslint frontend/src frontend/test frontend/e2e/*.js",
    "test": "npm run lint && npm run test:unit",
    "test:unit": "vitest run frontend/test --environment jsdom",
    "test:e2e": "playwright test frontend/e2e/panel.spec.js",
    "check:generated": "npm run build && git diff --exit-code -- custom_components/codex_bridge/frontend/codex-bridge-panel.js custom_components/codex_bridge/frontend/codex-bridge-pdf-worker.js",
    "brand:render": "node scripts/render-brand-assets.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "pdfjs-dist": "6.1.200",
    "vitest": "4.1.10"
  }
}
