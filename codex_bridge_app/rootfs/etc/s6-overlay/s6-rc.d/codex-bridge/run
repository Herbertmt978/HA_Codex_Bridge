#!/usr/bin/with-contenv bash
# shellcheck shell=bash
set -Eeuo pipefail

# Supervisor validates this as a boolean, and this second check keeps malformed
# restored option state fail-closed before it reaches the Bridge process.
source /usr/lib/bashio/bashio.sh
enable_mcp="$(bashio::config 'enable_mcp')"
case "${enable_mcp}" in
    true|false) ;;
    *)
        bashio::log.fatal "The enable_mcp option must be a boolean."
        exit 1
        ;;
esac

# Deliberately construct the service environment from an allowlist. In
# particular, the Supervisor credential is neither inherited nor re-exported
# to Bridge, Codex, or model-controlled tools.
cd /config/workspaces
exec s6-setuidgid codexbridge env -i \
    PATH=/opt/codex/bin:/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin \
    HOME=/data/codex-home \
    CODEX_HOME=/data/codex-home \
    TMPDIR=/tmp/codex-bridge \
    LANG=C.UTF-8 \
    CODEX_BRIDGE_AUTH_TOKEN_FILE=/data/bridge-token \
    CODEX_BRIDGE_HOST=0.0.0.0 \
    CODEX_BRIDGE_PORT=8766 \
    CODEX_BRIDGE_ROOT_PATH=/data/bridge \
    CODEX_BRIDGE_WORKSPACE_ROOT=/config/workspaces \
    CODEX_BRIDGE_RUNTIME_PROFILE=home_assistant \
    CODEX_BRIDGE_ENABLE_MCP="${enable_mcp}" \
    CODEX_BRIDGE_CODEX_WRAPPER_PATH=/usr/local/bin/codex-ha \
    CODEX_BRIDGE_APP_VERSION=0.8.5 \
    CODEX_BRIDGE_VERSION=0.7.3 \
    CODEX_BRIDGE_CODEX_VERSION=0.144.5 \
    CODEX_BRIDGE_ARCH=amd64 \
    CODEX_BRIDGE_RELEASE_LOCK_DIGEST=0757937e7e7ecd07477f7ef7bd61d86edf43ac3181ef28353d139c6424580fed \
    CODEX_BRIDGE_SANDBOX_CONTRACT_VERSION=2 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    python -m uvicorn codex_bridge_service.main:app --host 0.0.0.0 --port 8766 --workers 1
